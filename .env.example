NEXT_PUBLIC_DOC_URL=https://docs.canvas.best
APP_PUBLIC_URL=
# Docker Compose 对外端口，示例：3000 或 127.0.0.1:3010。
APP_PORT=3000

# EggAi登录门禁。LOGTO_ISSUER 通常是 Logto 的 OIDC Issuer，例如 https://tenant.logto.app/oidc。
LOGTO_ISSUER=
# Docker bridge 网络部署时可选：浏览器仍使用 LOGTO_ISSUER，服务端请求走内部地址。
LOGTO_INTERNAL_ISSUER=
LOGTO_CLIENT_ID=
LOGTO_CLIENT_SECRET=
LOGTO_SCOPE=openid profile email

# 用于加密 HttpOnly session cookie，请使用足够长的随机字符串。
SESSION_SECRET=
# 需要强制 Secure Cookie 时设为 true；本地 HTTP 调试保持空即可。
COOKIE_SECURE=

# New API 轻代理。登录后会通过 Logto resource token 读取 New API 的模型和令牌。
NEW_API_BASE_URL=
NEW_API_PUBLIC_URL=
NEW_API_DISPLAY_NAME=New API
NEW_API_LOGTO_AUDIENCE=
NEW_API_LOGTO_SCOPE=ecosystem:me ecosystem:models:read ecosystem:tokens:read
